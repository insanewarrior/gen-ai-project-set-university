# DynamoDB endpoint — set for local dev, leave unset for AWS
DYNAMODB_ENDPOINT=http://localhost:8000

# Auth bypass — "true" skips Cognito verification for local dev
AUTH_BYPASS=true

# Claude model ID for AI coaching
CLAUDE_MODEL=claude-sonnet-4-5-20250514

# Test user ID for local development
TEST_USER_ID=test-user-001

# FAISS index path for knowledge base
FAISS_INDEX_PATH=./data/faiss_index
