# Copy this file to .env.local and fill in values.
#
# --- LOCAL DEV (no Cognito needed) ---
# Set this to true to skip Cognito sign-in entirely.
# Matches AUTH_BYPASS=true in backend/.env — the backend injects TEST_USER_ID automatically.
VITE_AUTH_BYPASS=true

# --- PRODUCTION (after `make deploy`) ---
# Get UserPoolId and ClientId from: infra/cdk-outputs.json → UserPoolId / UserPoolClientId
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=

# Backend API URL for local development
VITE_API_URL=http://localhost:8080
